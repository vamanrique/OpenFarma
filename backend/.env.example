# === Base de datos ===
# Ruta al archivo SQLite. En Railway el volumen está en /data/
DATABASE_URL=sqlite:///./openfarma.db

# === Seguridad ===
# Cambia esto en producción. Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# === Entorno ===
# "development" desactiva algunas validaciones. En Railway usar "production"
ENVIRONMENT=development

# === CORS ===
# Orígenes permitidos para el frontend. En Railway usar * o la URL del servicio.
CORS_ORIGINS=http://localhost:5173

# === Socrata / datos.gov.co (opcional pero recomendado en producción) ===
# Registra tu app en datos.gov.co → perfil → App Tokens
# Sin token: ~1000 req/día por IP. Con token: 100K req/día por token.
SOCRATA_APP_TOKEN=your-app-token-here

# === DeepSeek API (obligatorio para ETL de clasificación ATC) ===
# Obtén tu clave en https://platform.deepseek.com
# Solo requerida para ejecutar el ETL de grupos (construir_grupos.py, retrain_invima.py)
# No es necesaria para arrancar el backend o hacer búsquedas
DEEPSEEK_API_KEY=sk-your-key-here
